{
    "manifest_version": 2,
    "name": "GitHub shortcuts",
    "version": "1.2",
    "description": "Add some shortcuts to GitHub pages.",

    "browser_specific_settings": {
        "gecko": {
            "id": "silpheel@gmail.com",
            "strict_min_version": "140.0",
            "data_collection_permissions": {
                "required": ["none"]
            }
        }
    },

    "content_scripts": [
        {
            "matches": ["*://github.com/*", "*://*.github.com/*"],
            "js": ["addbuttons.js"],
            "run_at": "document_idle"
        }
    ],
    "icons": {
        "48": "icon.svg",
        "96": "icon.svg",
        "128": "icon.svg"
    }
}
